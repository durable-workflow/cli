{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://durable-workflow.com/schemas/cli/output/server-health.schema.json",
  "title": "dw server:health --output=json",
  "description": "Server health probe output for scripts, diagnostics, and agent preflight checks.",
  "type": "object",
  "required": ["status", "timestamp"],
  "properties": {
    "status": {
      "type": "string",
      "description": "Overall server health state, such as ok, degraded, or error."
    },
    "timestamp": {
      "type": "string",
      "description": "Server-side probe timestamp."
    },
    "checks": {
      "type": "object",
      "description": "Named subsystem health checks.",
      "additionalProperties": {
        "type": ["string", "boolean", "number", "object", "array", "null"]
      }
    }
  },
  "additionalProperties": true
}
