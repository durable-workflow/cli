{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://durable-workflow.com/schemas/cli/output/schedule-history.schema.json",
  "title": "dw schedule:history --json",
  "type": "object",
  "required": ["schedule_id", "events"],
  "properties": {
    "schedule_id": { "type": "string" },
    "namespace": { "type": ["string", "null"] },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sequence", "event_type"],
        "properties": {
          "id": { "type": ["string", "null"] },
          "sequence": { "type": "integer", "minimum": 1 },
          "event_type": { "type": ["string", "null"] },
          "recorded_at": { "type": ["string", "null"] },
          "workflow_instance_id": { "type": ["string", "null"] },
          "workflow_run_id": { "type": ["string", "null"] },
          "payload": { "type": ["object", "array"] }
        },
        "additionalProperties": true
      }
    },
    "has_more": { "type": "boolean" },
    "next_cursor": { "type": ["integer", "null"] }
  },
  "additionalProperties": true
}
