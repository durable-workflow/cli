{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://durable-workflow.com/schemas/cli/output/schedule-list.schema.json",
  "title": "dw schedule:list --json",
  "type": "object",
  "required": ["namespace", "schedules"],
  "properties": {
    "namespace": { "type": "string" },
    "schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["namespace", "schedule_id"],
        "properties": {
          "namespace": { "type": "string" },
          "schedule_id": { "type": "string" },
          "workflow_type": { "type": ["string", "null"] },
          "paused": { "type": ["boolean", "null"] },
          "next_fire": { "type": ["string", "null"] },
          "next_fire_at": { "type": ["string", "null"] },
          "last_fire": { "type": ["string", "null"] },
          "last_fire_at": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
