{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://durable-workflow.com/schemas/cli/output/workflow-run.schema.json",
  "title": "dw workflow:describe/show-run --json",
  "type": "object",
  "required": ["workflow_id"],
  "properties": {
    "workflow_id": { "type": "string" },
    "run_id": { "type": ["string", "null"] },
    "workflow_type": { "type": ["string", "null"] },
    "namespace": { "type": ["string", "null"] },
    "business_key": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"] },
    "status_bucket": { "type": ["string", "null"] },
    "run_number": { "type": ["integer", "null"] },
    "run_count": { "type": ["integer", "null"] },
    "is_current_run": { "type": ["boolean", "null"] },
    "is_terminal": { "type": ["boolean", "null"] },
    "task_queue": { "type": ["string", "null"] },
    "compatibility": { "type": ["string", "null"] },
    "payload_codec": { "type": ["string", "null"] },
    "execution_timeout_seconds": { "type": ["integer", "null"] },
    "run_timeout_seconds": { "type": ["integer", "null"] },
    "execution_deadline_at": { "type": ["string", "null"] },
    "run_deadline_at": { "type": ["string", "null"] },
    "started_at": { "type": ["string", "null"] },
    "closed_at": { "type": ["string", "null"] },
    "last_progress_at": { "type": ["string", "null"] },
    "closed_reason": { "type": ["string", "null"] },
    "wait_kind": { "type": ["string", "null"] },
    "wait_reason": { "type": ["string", "null"] },
    "input": true,
    "output": true,
    "memo": { "type": ["object", "array", "null"] },
    "search_attributes": { "type": ["object", "null"] },
    "actions": { "type": ["object", "null"], "additionalProperties": { "type": "boolean" } }
  },
  "additionalProperties": true
}
