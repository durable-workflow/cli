{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://durable-workflow.com/schemas/cli/config/external-executor.schema.json",
  "title": "Durable Workflow external executor config",
  "description": "Carrier-neutral handler mapping config for bounded activity-grade external execution.",
  "type": "object",
  "required": ["schema", "version", "mappings", "carriers"],
  "properties": {
    "schema": {
      "const": "durable-workflow.external-executor.config"
    },
    "version": {
      "const": 1
    },
    "defaults": {
      "type": "object",
      "properties": {
        "profile": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "task_queue": { "type": "string", "minLength": 1 },
        "auth_ref": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "auth_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["profile", "env", "token_file", "mtls", "signed_headers"] },
          "profile": { "type": "string", "minLength": 1 },
          "env": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
          "path": { "type": "string", "minLength": 1 },
          "cert": { "type": "string", "minLength": 1 },
          "key_ref": { "type": "string", "minLength": 1 },
          "header_allowlist": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "carriers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["process", "http", "invocable_http", "sqs", "webhook"] },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "url": { "type": "string", "format": "uri" },
          "queue_url": { "type": "string", "format": "uri" },
          "method": { "type": "string", "enum": ["POST", "PUT"] },
          "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["activity_task", "workflow_start", "workflow_signal", "workflow_update", "webhook_ingress"]
            },
            "uniqueItems": true
          },
          "environment": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping" }
    },
    "overlays": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "defaults": { "$ref": "#/properties/defaults" },
          "carriers": { "$ref": "#/properties/carriers" },
          "mappings": {
            "type": "array",
            "items": { "$ref": "#/$defs/mapping" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "required": ["name", "kind", "carrier", "handler"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["activity", "workflow_start", "workflow_signal", "workflow_update", "webhook_ingress"]
        },
        "task_queue": { "type": "string", "minLength": 1 },
        "activity_type": { "type": "string", "minLength": 1 },
        "workflow_type": { "type": "string", "minLength": 1 },
        "signal_name": { "type": "string", "minLength": 1 },
        "update_name": { "type": "string", "minLength": 1 },
        "carrier": { "type": "string", "minLength": 1 },
        "handler": { "type": "string", "minLength": 1 },
        "auth_ref": { "type": "string", "minLength": 1 },
        "idempotency_key": { "type": "string", "minLength": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "rollout": {
          "type": "object",
          "properties": {
            "version": { "type": "string", "minLength": 1 },
            "percentage": { "type": "integer", "minimum": 0, "maximum": 100 },
            "capability": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "x-durable-workflow-validation": {
    "auth_composition_contract": {
      "schema": "durable-workflow.v2.auth-composition.contract",
      "version": 1,
      "redaction": "auth_refs persist references only; bearer tokens, private keys, and signing secrets must never be stored inline"
    },
    "named_errors": [
      "unknown_carrier",
      "unknown_auth_ref",
      "duplicate_mapping_name",
      "invalid_queue_binding",
      "missing_handler_target",
      "unsupported_carrier_capability"
    ]
  },
  "additionalProperties": false
}
