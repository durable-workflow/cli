{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://durable-workflow.com/schemas/cli/output/task-queue.schema.json",
  "title": "dw task-queue:describe --json",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string" },
    "stats": { "type": ["object", "null"], "additionalProperties": true },
    "current_leases": { "type": ["array", "null"], "items": { "type": "object", "additionalProperties": true } },
    "pollers": { "type": ["array", "null"], "items": { "type": "object", "additionalProperties": true } }
  },
  "additionalProperties": true
}
